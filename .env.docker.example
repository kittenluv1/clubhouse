# ============================================================
# BruinSphere — Local Docker Dev Environment
# Copy to .env.docker and fill in the two Google OAuth values.
# ============================================================

# --- PostgreSQL ---
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# --- JWT (dev-only, safe to leave as-is) ---
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRFA0NiK7urfjjDvty2iEVwgs1ZnNACjd5drepr_3-I
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hj04zWl196z2-SBc

# --- Next.js ---
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRFA0NiK7urfjjDvty2iEVwgs1ZnNACjd5drepr_3-I
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hj04zWl196z2-SBc
NEXT_PUBLIC_ADMIN_EMAIL=your-admin-email@example.com

# --- GoTrue (auth service) ---
GOTRUE_JWT_EXP=3600
GOTRUE_SITE_URL=http://localhost:3000
GOTRUE_EXTERNAL_GOOGLE_REDIRECT_URI=http://localhost:8000/auth/v1/callback

# ⚠️  FILL THESE IN — same Google OAuth credentials as your hosted Supabase project
# Get from: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# Also add http://localhost:8000/auth/v1/callback as an authorized redirect URI there.
GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID=your-google-client-id
GOTRUE_EXTERNAL_GOOGLE_SECRET=your-google-client-secret
